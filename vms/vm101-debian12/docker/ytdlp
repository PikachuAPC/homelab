version: '3.8'

services:
  ytdl:
    image: tzahi12345/youtubedl-material:latest
    container_name: ytdl
    restart: unless-stopped
    ports:
      - "8998:17442"
    environment:
      - ALLOW_MULTI_SELECT=true
      - ytdl_mongodb_connection_string=mongodb://mongo:27017
      - ytdl_use_local_db=false
      - YTDLP_OPTIONS=--extractor-args youtube:player_client=android
    volumes:
      - ./appdata:/app/appdata
      - ./audio:/app/audio
      - ./video:/app/video  #esto esta sin tocar pq lo uso en web al 100%
    depends_on:
      - mongo

  mongo:
    image: mongo:4.4
    container_name: ytdl-mongo
    restart: unless-stopped
    volumes:
      - ./mongo_data:/data/db
